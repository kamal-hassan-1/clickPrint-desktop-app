{
  "name": "clickprint-desktop-app",
  "version": "1.0.0",
  "description": "ClickPrint Desktop Application",
  "main": "main/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "cd renderer && npx vite --port 3000",
    "dev:electron": "node scripts/wait-for-renderer.js && electron .",
    "build:renderer": "cd renderer && npx vite build",
    "build": "npm run build:renderer && electron-builder",
    "start": "electron ."
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.7"
  },
  "build": {
    "appId": "com.clickprint.desktop",
    "productName": "ClickPrint",
    "files": [
      "main/**/*",
      "renderer/dist/**/*"
    ],
    "directories": {
      "output": "dist"
    }
  }
}
