{
  "name": "clickprint-desktop-app",
  "version": "1.0.4",
  "description": "ClickPrint Desktop Application",
  "main": "main/main.js",
  "author": {
    "name": "WeCode",
    "email": "support@wecode.com.pk",
    "url": "https://wecode.com.pk/"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "cd renderer && npx vite --port 3001",
    "dev:electron": "node scripts/wait-for-renderer.js && electron .",
    "build:renderer": "cd renderer && npx vite build",
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "release": "dotenv -e .env -- electron-builder --publish always",
    "release-win": "dotenv -e .env -- electron-builder --publish always --win",
    "release-mac": "dotenv -e .env -- electron-builder --publish always --mac",
    "release-linux": "dotenv -e .env -- electron-builder --publish always --linux"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.9",
    "eventsource": "^1.1.2",
    "react-router-dom": "^7.18.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "dotenv-cli": "^11.0.0",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-icon-builder": "^2.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.7"
  },
  "build": {
    "appId": "com.clickprint.clickPrintDesktop",
    "productName": "Click Print Desktop",
    "files": [
      "**/*",
      "!**/node_modules/*/{CHANGELOG.md,README.md,readme.md}"
    ],
    "publish": {
      "provider": "github",
      "owner": "WeCodePK",
      "repo": "ClickPrintDesktop"
    },
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icons/icon.ico",
      "artifactName": "${productName}-Setup.${ext}"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icons/icon.icns"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icons/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "portable": {
      "artifactName": "${productName}-Portable.${ext}"
    }
  }
}
